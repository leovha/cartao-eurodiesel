<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leandro | Euro Diesel</title>
    <style>
        :root {
            --primary: #d4af37; /* Dourado Premium */
            --bg: #0a0a0a;
            --card-bg: #1a1a1a;
            --text: #ffffff;
            --secondary: #888888;
        }

        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: var(--bg);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--text);
        }

        .card {
            background: var(--card-bg);
            width: 350px;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 10px rgba(212, 175, 55, 0.1);
            border: 1px solid rgba(212, 175, 55, 0.2);
            position: relative;
            overflow: hidden;
        }

        /* Detalhe de luxo no topo */
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .logo-area {
            font-size: 1.2rem;
            letter-spacing: 4px;
            color: var(--primary);
            margin-bottom: 30px;
            font-weight: bold;
            text-transform: uppercase;
        }

        h1 {
            font-size: 1.8rem;
            margin: 10px 0 5px 0;
            letter-spacing: 1px;
        }

        .job-title {
            color: var(--secondary);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
        }

        .contact-link {
            display: block;
            background: transparent;
            color: var(--text);
            text-decoration: none;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .contact-link:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(212, 175, 55, 0.05);
            transform: translateY(-2px);
        }

        .whatsapp-btn {
            background: var(--primary);
            color: #000 !important;
            border: none;
            margin-top: 20px;
        }

        .whatsapp-btn:hover {
            background: #f1c40f;
            transform: scale(1.05);
        }

        .footer-brand {
            margin-top: 40px;
            font-size: 0.7rem;
            color: var(--secondary);
            opacity: 0.5;
        }
    </style>
</head>
<body>

    <div class="card">
        <div class="logo-area">EURO DIESEL</div>
        
        <h1>LEANDRO</h1>
        <p class="job-title">Gerente Financeiro</p>

        <hr style="border: 0; border-top: 1px solid rgba(212, 175, 55, 0.2); margin-bottom: 25px;">

        <a href="https://wa.me/5569981128233" class="contact-link whatsapp-btn" target="_blank">
            WHATSAPP CORPORATIVO
        </a>

        <a href="https://www.google.com/maps/place/Euro+Diesel+Especializada+linha+Volvo+Scania+Mecatronica+Inje%C3%A7%C3%A3o+Eletronica+Catalizador+Modulos+Centrais+Vilhena+RO/data=!4m2!3m1!1s0x0:0xe56ce9eadefe2e90?sa=X&ved=1t:2428&ictx=111" class="contact-link" target="_blank">
            LOCALIZAÇÃO DA EMPRESA
        </a>

        <a href="mailto:seuemail@exemplo.com" class="contact-link">
            ENVIAR E-MAIL
        </a>

        <div class="footer-brand">
            &copy; 2026 EURO DIESEL - EXCELÊNCIA EM COMBUSTÍVEIS
        </div>
    </div>

</body>
</html>
